{% liquid
  assign hero_content = metaobjects['luxe_hero_content']['default']

  assign badge_text = hero_content.badge_text | default: 'Premium storefront'
  assign heading = hero_content.heading | default: 'A cleaner, sharper first impression for your Shopify store'
  assign subheading = hero_content.subheading | default: 'Show a stronger brand message, clear value, and a more premium visual style without needing to touch code.'
  assign button_label = hero_content.primary_button_label | default: 'Shop the collection'
  assign secondary_button_label = hero_content.secondary_button_label | default: 'Learn more'
  assign content_alignment = hero_content.content_alignment | default: 'left'
  assign background_preset = hero_content.background_preset | default: 'midnight'
  assign overlay_opacity = hero_content.overlay_opacity | default: 34 | times: 0.01
  assign section_height = hero_content.desktop_height | default: 560
  assign mobile_section_height = hero_content.mobile_height | default: 460

  assign primary_button_link = hero_content.primary_button_link | default: block.settings.button_link
  assign secondary_button_link = hero_content.secondary_button_link | default: block.settings.secondary_button_link

  assign metaobject_background_image = hero_content.background_image | default: blank
  assign metaobject_background_video = hero_content.background_video | default: blank

  assign block_background_image = block.settings.background_image
  assign block_background_video = block.settings.background_video

  assign padding_top = hero_content.padding_top | default: block.settings.padding_top
  assign padding_bottom = hero_content.padding_bottom | default: block.settings.padding_bottom
  assign mobile_padding_top = hero_content.mobile_padding_top | default: block.settings.mobile_padding_top
  assign mobile_padding_bottom = hero_content.mobile_padding_bottom | default: block.settings.mobile_padding_bottom
%}

{% liquid
  case background_preset
    when 'champagne'
      assign section_background = 'linear-gradient(135deg, #2c2014 0%, #6f5631 48%, #d6b37a 100%)'
    when 'charcoal'
      assign section_background = 'linear-gradient(135deg, #111827 0%, #1f2937 58%, #4b5563 100%)'
    else
      assign section_background = 'linear-gradient(135deg, #0f172a 0%, #182235 56%, #8a6a2f 100%)'
  endcase
%}

<div
  id="LuxeHero-{{ block.id }}"
  class="luxe-hero-section"
  style="background: {{ section_background }};"
>
  <div class="luxe-hero__background">
    {% if block_background_video != blank %}
      <div class="luxe-hero__video-container">
        {{
          block_background_video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: false,
            class: 'luxe-hero__video'
        }}
      </div>
    {% elsif metaobject_background_video != blank %}
      <div class="luxe-hero__video-container">
        <video
          class="luxe-hero__video"
          autoplay
          loop
          muted
          playsinline
        >
          <source src="{{ metaobject_background_video }}">
        </video>
      </div>
    {% elsif block_background_image != blank %}
      {{
        block_background_image
        | image_url: width: 2400
        | image_tag:
          class: 'luxe-hero__image',
          loading: 'lazy',
          sizes: '100vw',
          alt: heading
      }}
    {% elsif metaobject_background_image != blank %}
      <img
        class="luxe-hero__image"
        src="{{ metaobject_background_image }}"
        alt="{{ heading | escape }}"
        loading="lazy"
      >
    {% else %}
      <div class="luxe-hero__placeholder"></div>
    {% endif %}

    <div
      class="luxe-hero__overlay"
      style="opacity: {{ overlay_opacity }};"
    ></div>
  </div>

  <div class="luxe-hero__ambient-glow"></div>

  <div class="luxe-hero__content-wrapper page-width">
    <div class="luxe-hero__content luxe-hero__content--{{ content_alignment }}">
      {% if badge_text != blank %}
        <div class="luxe-hero__badge">{{ badge_text }}</div>
      {% endif %}

      {% if heading != blank %}
        <h2 class="luxe-hero__heading">{{ heading }}</h2>
      {% endif %}

      {% if subheading != blank %}
        <div class="luxe-hero__subheading">{{ subheading }}</div>
      {% endif %}

      {% if button_label != blank or secondary_button_label != blank %}
        <div class="luxe-hero__actions">
          {% if button_label != blank %}
            {% if primary_button_link != blank %}
              <a class="luxe-hero__button luxe-hero__button--primary" href="{{ primary_button_link }}">
                {{ button_label }}
              </a>
            {% else %}
              <span class="luxe-hero__button luxe-hero__button--primary">
                {{ button_label }}
              </span>
            {% endif %}
          {% endif %}

          {% if secondary_button_label != blank %}
            {% if secondary_button_link != blank %}
              <a class="luxe-hero__button luxe-hero__button--secondary" href="{{ secondary_button_link }}">
                {{ secondary_button_label }}
              </a>
            {% else %}
              <span class="luxe-hero__button luxe-hero__button--secondary">
                {{ secondary_button_label }}
              </span>
            {% endif %}
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  #LuxeHero-{{ block.id }} {
    position: relative;
    min-height: {{ section_height }}px;
    border-radius: 28px;
    overflow: hidden;
    color: #ffffff;
    isolation: isolate;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__background {
    position: absolute;
    inset: 0;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__video-container,
  #LuxeHero-{{ block.id }} .luxe-hero__image,
  #LuxeHero-{{ block.id }} .luxe-hero__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__video-container video,
  #LuxeHero-{{ block.id }} .luxe-hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__image {
    object-fit: cover;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__placeholder {
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.14), transparent 34%),
      linear-gradient(135deg, rgba(255,255,255,0.04) 0%, rgba(0,0,0,0.18) 100%);
  }

  #LuxeHero-{{ block.id }} .luxe-hero__overlay {
    position: absolute;
    inset: 0;
    background: #0f172a;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__ambient-glow {
    position: absolute;
    right: 4%;
    top: 12%;
    width: 320px;
    height: 320px;
    border-radius: 999px;
    background:
      radial-gradient(circle, rgba(248,231,176,0.34) 0%, rgba(248,231,176,0.10) 38%, rgba(248,231,176,0) 72%);
    filter: blur(10px);
    z-index: 1;
    pointer-events: none;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content-wrapper {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    min-height: {{ section_height }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content {
    width: 100%;
    max-width: 620px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--left {
    text-align: left;
    margin-right: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--right {
    text-align: right;
    margin-left: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__badge {
    display: inline-flex;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(248, 231, 176, 0.16);
    color: #f8e7b0;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__heading {
    margin: 0 0 16px;
    font-size: clamp(40px, 6vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.03em;
    color: #ffffff;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__subheading {
    max-width: 620px;
    font-size: 17px;
    line-height: 1.7;
    color: rgba(255,255,255,0.84);
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--center .luxe-hero__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--right .luxe-hero__subheading {
    margin-left: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 28px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--center .luxe-hero__actions {
    justify-content: center;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--right .luxe-hero__actions {
    justify-content: flex-end;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 50px;
    padding: 0 24px;
    border-radius: 999px;
    text-decoration: none;
    font-size: 14px;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button--primary {
    background: #f8e7b0;
    color: #1f2937;
    font-weight: 700;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button--secondary {
    background: rgba(255, 255, 255, 0.08);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.22);
    backdrop-filter: blur(6px);
    font-weight: 600;
  }

  @media screen and (max-width: 749px) {
    #LuxeHero-{{ block.id }} {
      min-height: auto;
      border-radius: 20px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__ambient-glow {
      right: -50px;
      top: auto;
      bottom: -70px;
      width: 180px;
      height: 180px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__content-wrapper {
      min-height: {{ mobile_section_height }}px;
      padding-top: {{ mobile_padding_top }}px;
      padding-bottom: {{ mobile_padding_bottom }}px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__heading {
      font-size: clamp(30px, 9vw, 42px);
    }

    #LuxeHero-{{ block.id }} .luxe-hero__subheading {
      font-size: 14px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__actions {
      flex-direction: column;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Premium Hero Banner",
  "target": "section",
  "settings": [
    {
      "type": "video",
      "id": "background_video",
      "label": "Background video"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile top padding",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile bottom padding",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}