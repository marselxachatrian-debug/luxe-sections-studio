{% liquid
  assign heading = block.settings.heading
  assign subheading = block.settings.subheading
  assign button_label = block.settings.button_label
  assign button_link = block.settings.button_link
  assign secondary_button_label = block.settings.secondary_button_label
  assign secondary_button_link = block.settings.secondary_button_link
  assign background_image = block.settings.background_image
  assign background_video = block.settings.background_video
  assign overlay_opacity = block.settings.overlay_opacity | times: 0.01
  assign section_height = block.settings.section_height
  assign mobile_section_height = block.settings.mobile_section_height
  assign content_alignment = block.settings.content_alignment
  assign padding_top = block.settings.padding_top
  assign padding_bottom = block.settings.padding_bottom
  assign mobile_padding_top = block.settings.mobile_padding_top
  assign mobile_padding_bottom = block.settings.mobile_padding_bottom
  assign enable_glow_effects = block.settings.enable_glow_effects
  assign animation_preset = block.settings.animation_preset
%}

<div id="LuxeHero-{{ block.id }}" class="luxe-hero-section">
  <div class="luxe-hero__background">
    {% if background_video != blank %}
      <div class="luxe-hero__video-container">
        {{
          background_video
          | video_tag:
            autoplay: true,
            loop: true,
            muted: true,
            controls: false
        }}
      </div>
    {% elsif background_image != blank %}
      {{
        background_image
        | image_url: width: 2400
        | image_tag:
          class: 'luxe-hero__image',
          loading: 'lazy',
          sizes: '100vw'
      }}
    {% else %}
      <div class="luxe-hero__placeholder"></div>
    {% endif %}

    <div
      class="luxe-hero__overlay"
      style="opacity: {{ overlay_opacity }};"
    ></div>
  </div>

  <div class="luxe-hero__content-wrapper page-width">
    <div class="luxe-hero__content luxe-hero__content--{{ content_alignment }}{% if enable_glow_effects %} luxe-hero__content--glow{% endif %}{% if animation_preset != 'none' %} luxe-hero__content--animate-{{ animation_preset }}{% endif %}">
      {% if heading != blank %}
        <h2 class="luxe-hero__heading">{{ heading }}</h2>
      {% endif %}

      {% if subheading != blank %}
        <div class="luxe-hero__subheading">{{ subheading }}</div>
      {% endif %}

      {% if button_label != blank and button_link != blank or secondary_button_label != blank and secondary_button_link != blank %}
        <div class="luxe-hero__actions">
          {% if button_label != blank and button_link != blank %}
            <a class="luxe-hero__button luxe-hero__button--primary" href="{{ button_link }}">
              {{ button_label }}
            </a>
          {% endif %}

          {% if secondary_button_label != blank and secondary_button_link != blank %}
            <a class="luxe-hero__button luxe-hero__button--secondary" href="{{ secondary_button_link }}">
              {{ secondary_button_label }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  #LuxeHero-{{ block.id }} {
    position: relative;
    min-height: {{ section_height }}px;
    border-radius: 24px;
    overflow: hidden;
    background: #111111;
    color: #ffffff;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__background {
    position: absolute;
    inset: 0;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__video-container,
  #LuxeHero-{{ block.id }} .luxe-hero__image,
  #LuxeHero-{{ block.id }} .luxe-hero__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__video-container video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__image {
    object-fit: cover;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__placeholder {
    background:
      radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 35%),
      linear-gradient(135deg, #1f1f1f 0%, #0f0f0f 100%);
  }

  #LuxeHero-{{ block.id }} .luxe-hero__overlay {
    position: absolute;
    inset: 0;
    background: #000000;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content-wrapper {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    min-height: {{ section_height }}px;
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content {
    max-width: 720px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--left {
    text-align: left;
    margin-right: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--center {
    text-align: center;
    margin-left: auto;
    margin-right: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--glow {
    padding: 28px;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(10px);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.04),
      0 18px 50px rgba(0, 0, 0, 0.24),
      0 0 60px rgba(255, 255, 255, 0.12);
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--animate-fade-up {
    animation: luxeHeroFadeUp 0.8s ease both;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--animate-zoom-in {
    animation: luxeHeroZoomIn 0.8s ease both;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__heading {
    margin: 0 0 16px;
    font-size: clamp(36px, 6vw, 68px);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__subheading {
    max-width: 560px;
    font-size: 18px;
    line-height: 1.6;
    opacity: 0.92;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--center .luxe-hero__subheading {
    margin-left: auto;
    margin-right: auto;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__content--center .luxe-hero__actions {
    justify-content: center;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, opacity 0.2s ease, background 0.2s ease;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button--primary {
    background: #ffffff;
    color: #111111;
  }

  #LuxeHero-{{ block.id }} .luxe-hero__button--secondary {
    background: rgba(255, 255, 255, 0.12);
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(6px);
  }

  @keyframes luxeHeroFadeUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes luxeHeroZoomIn {
    from {
      opacity: 0;
      transform: scale(0.94);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media screen and (max-width: 749px) {
    #LuxeHero-{{ block.id }} {
      min-height: auto;
      border-radius: 18px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__content-wrapper {
      min-height: {{ mobile_section_height }}px;
      padding-top: {{ mobile_padding_top }}px;
      padding-bottom: {{ mobile_padding_bottom }}px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__content--glow {
      padding: 20px;
      border-radius: 18px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__heading {
      font-size: clamp(28px, 9vw, 42px);
    }

    #LuxeHero-{{ block.id }} .luxe-hero__subheading {
      font-size: 16px;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__actions {
      flex-direction: column;
    }

    #LuxeHero-{{ block.id }} .luxe-hero__button {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Premium Hero Banner",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate your brand with a refined visual story"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Create a premium first impression with a clean hero layout, strong spacing, and a focused call to action."
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background video"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ]
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Learn more"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Mobile top padding",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Mobile bottom padding",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop section height",
      "min": 420,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 640
    },
    {
      "type": "range",
      "id": "mobile_section_height",
      "label": "Mobile section height",
      "min": 320,
      "max": 760,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "checkbox",
      "id": "enable_glow_effects",
      "label": "Enable glow effects",
      "default": false
    },
    {
      "type": "select",
      "id": "animation_preset",
      "label": "Animation preset",
      "default": "none",
      "options": [
        {
          "value": "none",
          "label": "None"
        },
        {
          "value": "fade-up",
          "label": "Fade up"
        },
        {
          "value": "zoom-in",
          "label": "Zoom in"
        }
      ]
    }
  ]
}
{% endschema %}