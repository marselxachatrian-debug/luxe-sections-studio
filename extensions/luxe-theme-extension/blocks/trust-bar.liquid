{% liquid
  assign trust_bar_content = metaobjects['trust_bar_content']['default']

  assign section_heading = trust_bar_content.heading | default: block.settings.heading | default: 'Why shoppers trust CasaBloom'
  assign heading_alignment = trust_bar_content.heading_alignment | default: block.settings.heading_alignment | default: 'center'
  assign section_style = trust_bar_content.section_style | default: block.settings.section_style | default: 'soft'
  assign desktop_columns = trust_bar_content.desktop_columns | default: block.settings.desktop_columns | default: '4'
  assign padding_top = trust_bar_content.padding_top | default: block.settings.padding_top | default: 32
  assign padding_bottom = trust_bar_content.padding_bottom | default: block.settings.padding_bottom | default: 32

  assign item_1_title = trust_bar_content.item_1_title | default: block.settings.item_1_title | default: 'Secure checkout'
  assign item_1_text = trust_bar_content.item_1_text | default: block.settings.item_1_text | default: 'Encrypted payments and trusted checkout experience.'
  assign item_2_title = trust_bar_content.item_2_title | default: block.settings.item_2_title | default: 'Fast fulfillment'
  assign item_2_text = trust_bar_content.item_2_text | default: block.settings.item_2_text | default: 'Quick dispatch and reliable delivery updates.'
  assign item_3_title = trust_bar_content.item_3_title | default: block.settings.item_3_title | default: 'Premium quality'
  assign item_3_text = trust_bar_content.item_3_text | default: block.settings.item_3_text | default: 'Carefully selected materials and elevated product standards.'
  assign item_4_title = trust_bar_content.item_4_title | default: block.settings.item_4_title | default: 'Responsive support'
  assign item_4_text = trust_bar_content.item_4_text | default: block.settings.item_4_text | default: 'Helpful customer support when shoppers need assistance.'

  case section_style
    when 'dark'
      assign section_background = '#111827'
      assign section_text = '#F9FAFB'
      assign card_background = 'rgba(255,255,255,0.08)'
      assign card_border = 'rgba(255,255,255,0.16)'
      assign muted_text = 'rgba(249,250,251,0.72)'
    when 'outline'
      assign section_background = '#FFFFFF'
      assign section_text = '#111827'
      assign card_background = '#FFFFFF'
      assign card_border = 'rgba(17,24,39,0.14)'
      assign muted_text = 'rgba(17,24,39,0.68)'
    else
      assign section_background = '#F8F5F0'
      assign section_text = '#1F2937'
      assign card_background = 'rgba(255,255,255,0.78)'
      assign card_border = 'rgba(17,24,39,0.08)'
      assign muted_text = 'rgba(31,41,55,0.66)'
  endcase
%}

{% style %}
  .luxe-trust-bar-{{ block.id }} {
    background: {{ section_background }};
    color: {{ section_text }};
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }

  .luxe-trust-bar__inner-{{ block.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .luxe-trust-bar__heading-{{ block.id }} {
    margin: 0 0 24px;
    text-align: {{ heading_alignment }};
    font-size: 28px;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .luxe-trust-bar__grid-{{ block.id }} {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .luxe-trust-bar__item-{{ block.id }} {
    background: {{ card_background }};
    border: 1px solid {{ card_border }};
    border-radius: 18px;
    padding: 20px 18px;
    backdrop-filter: blur(10px);
  }

  .luxe-trust-bar__item-title-{{ block.id }} {
    margin: 0 0 6px;
    color: {{ section_text }};
    font-size: 16px;
    line-height: 1.3;
    font-weight: 600;
  }

  .luxe-trust-bar__item-text-{{ block.id }} {
    margin: 0;
    color: {{ muted_text }};
    font-size: 14px;
    line-height: 1.55;
  }

  @media screen and (min-width: 750px) {
    .luxe-trust-bar__grid-{{ block.id }} {
      grid-template-columns: repeat({{ desktop_columns }}, minmax(0, 1fr));
    }
  }
{% endstyle %}

<div class="luxe-trust-bar-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="luxe-trust-bar__inner-{{ block.id }}">
    {% if section_heading != blank %}
      <h2 class="luxe-trust-bar__heading-{{ block.id }}">
        {{ section_heading | escape }}
      </h2>
    {% endif %}

    <div class="luxe-trust-bar__grid-{{ block.id }}">
      {% liquid
        assign item_1_has_content = false
        if item_1_title != blank or item_1_text != blank
          assign item_1_has_content = true
        endif

        assign item_2_has_content = false
        if item_2_title != blank or item_2_text != blank
          assign item_2_has_content = true
        endif

        assign item_3_has_content = false
        if item_3_title != blank or item_3_text != blank
          assign item_3_has_content = true
        endif

        assign item_4_has_content = false
        if item_4_title != blank or item_4_text != blank
          assign item_4_has_content = true
        endif
      %}

      {% if item_1_has_content %}
        <div class="luxe-trust-bar__item-{{ block.id }}">
          {% if item_1_title != blank %}
            <h3 class="luxe-trust-bar__item-title-{{ block.id }}">
              {{ item_1_title | escape }}
            </h3>
          {% endif %}

          {% if item_1_text != blank %}
            <p class="luxe-trust-bar__item-text-{{ block.id }}">
              {{ item_1_text | escape }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      {% if item_2_has_content %}
        <div class="luxe-trust-bar__item-{{ block.id }}">
          {% if item_2_title != blank %}
            <h3 class="luxe-trust-bar__item-title-{{ block.id }}">
              {{ item_2_title | escape }}
            </h3>
          {% endif %}

          {% if item_2_text != blank %}
            <p class="luxe-trust-bar__item-text-{{ block.id }}">
              {{ item_2_text | escape }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      {% if item_3_has_content %}
        <div class="luxe-trust-bar__item-{{ block.id }}">
          {% if item_3_title != blank %}
            <h3 class="luxe-trust-bar__item-title-{{ block.id }}">
              {{ item_3_title | escape }}
            </h3>
          {% endif %}

          {% if item_3_text != blank %}
            <p class="luxe-trust-bar__item-text-{{ block.id }}">
              {{ item_3_text | escape }}
            </p>
          {% endif %}
        </div>
      {% endif %}

      {% if item_4_has_content %}
        <div class="luxe-trust-bar__item-{{ block.id }}">
          {% if item_4_title != blank %}
            <h3 class="luxe-trust-bar__item-title-{{ block.id }}">
              {{ item_4_title | escape }}
            </h3>
          {% endif %}

          {% if item_4_text != blank %}
            <p class="luxe-trust-bar__item-text-{{ block.id }}">
              {{ item_4_text | escape }}
            </p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Store Trust Highlights",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why shoppers trust CasaBloom"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "select",
      "id": "section_style",
      "label": "Section style",
      "default": "soft",
      "options": [
        { "value": "soft", "label": "Soft" },
        { "value": "dark", "label": "Dark" },
        { "value": "outline", "label": "Outline" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "default": "4",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Trust item 1"
    },
    {
      "type": "text",
      "id": "item_1_title",
      "label": "Title",
      "default": "Secure checkout"
    },
    {
      "type": "text",
      "id": "item_1_text",
      "label": "Text",
      "default": "Encrypted payments and trusted checkout experience."
    },
    {
      "type": "header",
      "content": "Trust item 2"
    },
    {
      "type": "text",
      "id": "item_2_title",
      "label": "Title",
      "default": "Fast fulfillment"
    },
    {
      "type": "text",
      "id": "item_2_text",
      "label": "Text",
      "default": "Quick dispatch and reliable delivery updates."
    },
    {
      "type": "header",
      "content": "Trust item 3"
    },
    {
      "type": "text",
      "id": "item_3_title",
      "label": "Title",
      "default": "Premium quality"
    },
    {
      "type": "text",
      "id": "item_3_text",
      "label": "Text",
      "default": "Carefully selected materials and elevated product standards."
    },
    {
      "type": "header",
      "content": "Trust item 4"
    },
    {
      "type": "text",
      "id": "item_4_title",
      "label": "Title",
      "default": "Responsive support"
    },
    {
      "type": "text",
      "id": "item_4_text",
      "label": "Text",
      "default": "Helpful customer support when shoppers need assistance."
    }
  ]
}
{% endschema %}