{% liquid
  assign showcase_content = metaobjects['trust_payments_showcase_content']['default']

  assign section_eyebrow = showcase_content.eyebrow | default: 'Trusted checkout'
  assign section_heading = showcase_content.heading | default: 'Build more purchase confidence with trust, payments, and delivery proof'
  assign section_subheading = showcase_content.subheading | default: 'Combine reassurance messaging, secure payment methods, and delivery partners in one premium conversion section.'

  assign trust_point_1 = showcase_content.trust_point_1 | default: 'Verified customer confidence'
  assign trust_point_2 = showcase_content.trust_point_2 | default: 'Secure payment support'
  assign trust_point_3 = showcase_content.trust_point_3 | default: 'Delivery partner visibility'

  assign partner_1 = showcase_content.partner_1 | default: 'Visa'
  assign partner_2 = showcase_content.partner_2 | default: 'Mastercard'
  assign partner_3 = showcase_content.partner_3 | default: 'PayPal'
  assign partner_4 = showcase_content.partner_4 | default: 'DHL'

  assign content_alignment = showcase_content.content_alignment | default: 'left'
  assign section_style = showcase_content.section_style | default: 'luxe'
  assign icon_tone = showcase_content.icon_tone | default: 'midnight'

  assign padding_top = block.settings.padding_top | default: 40
  assign padding_bottom = block.settings.padding_bottom | default: 40

  case section_style
    when 'soft'
      assign section_background = '#ffffff'
      assign section_border = 'rgba(15, 23, 42, 0.08)'
      assign section_shadow = '0 18px 34px rgba(15, 23, 42, 0.08)'
      assign heading_color = '#111827'
      assign text_color = '#6b7280'
      assign trust_card_background = '#ffffff'
      assign trust_card_border = 'rgba(15, 23, 42, 0.08)'
      assign partner_panel_background = '#ffffff'
      assign partner_panel_border = 'rgba(15, 23, 42, 0.08)'
      assign partner_item_background = '#f8fafc'
      assign partner_item_border = 'rgba(15, 23, 42, 0.08)'
    when 'minimal'
      assign section_background = '#f8fafc'
      assign section_border = 'rgba(15, 23, 42, 0.06)'
      assign section_shadow = '0 10px 24px rgba(15, 23, 42, 0.04)'
      assign heading_color = '#111827'
      assign text_color = '#6b7280'
      assign trust_card_background = '#ffffff'
      assign trust_card_border = 'rgba(15, 23, 42, 0.06)'
      assign partner_panel_background = '#ffffff'
      assign partner_panel_border = 'rgba(15, 23, 42, 0.06)'
      assign partner_item_background = '#f8fafc'
      assign partner_item_border = 'rgba(15, 23, 42, 0.08)'
    else
      assign section_background = 'linear-gradient(180deg, #fffdf8 0%, #ffffff 42%, #f8fafc 100%)'
      assign section_border = 'rgba(124, 92, 43, 0.14)'
      assign section_shadow = '0 20px 38px rgba(15, 23, 42, 0.08)'
      assign heading_color = '#111827'
      assign text_color = '#6b7280'
      assign trust_card_background = '#ffffff'
      assign trust_card_border = 'rgba(15, 23, 42, 0.08)'
      assign partner_panel_background = '#ffffff'
      assign partner_panel_border = 'rgba(15, 23, 42, 0.08)'
      assign partner_item_background = '#f8fafc'
      assign partner_item_border = 'rgba(15, 23, 42, 0.08)'
  endcase

  case icon_tone
    when 'gold'
      assign icon_background = 'linear-gradient(135deg, #f8e7b0 0%, #e8c56f 100%)'
    when 'charcoal'
      assign icon_background = 'linear-gradient(135deg, #111827 0%, #374151 100%)'
    else
      assign icon_background = 'linear-gradient(135deg, #0f172a 0%, #1f2937 70%, #7c5c2b 100%)'
  endcase
%}

{% style %}
  .luxe-trust-payments-showcase-{{ block.id }} {
    padding-top: {{ padding_top }}px;
    padding-bottom: {{ padding_bottom }}px;
  }

  .luxe-trust-payments-showcase__surface-{{ block.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 28px;
    border-radius: 28px;
    background: {{ section_background }};
    border: 1px solid {{ section_border }};
    box-shadow: {{ section_shadow }};
  }

  .luxe-trust-payments-showcase__grid-{{ block.id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: 18px;
    align-items: stretch;
  }

  .luxe-trust-payments-showcase__content-{{ block.id }} {
    text-align: {{ content_alignment }};
  }

  .luxe-trust-payments-showcase__eyebrow-wrap-{{ block.id }},
  .luxe-trust-payments-showcase__heading-wrap-{{ block.id }},
  .luxe-trust-payments-showcase__subheading-wrap-{{ block.id }} {
    display: flex;
    justify-content:
      {% if content_alignment == 'center' %}
        center
      {% elsif content_alignment == 'right' %}
        flex-end
      {% else %}
        flex-start
      {% endif %};
  }

  .luxe-trust-payments-showcase__eyebrow-{{ block.id }} {
    display: inline-flex;
    padding: 6px 12px;
    border-radius: 999px;
    background: rgba(248, 231, 176, 0.16);
    color: #7c5c2b;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .luxe-trust-payments-showcase__heading-{{ block.id }} {
    margin: 0 0 10px;
    color: {{ heading_color }};
    font-size: 30px;
    line-height: 1.15;
    font-weight: 700;
    max-width: 560px;
  }

  .luxe-trust-payments-showcase__subheading-{{ block.id }} {
    margin: 0 0 18px;
    color: {{ text_color }};
    font-size: 15px;
    line-height: 1.65;
    max-width: 580px;
  }

  .luxe-trust-payments-showcase__trust-list-{{ block.id }} {
    display: grid;
    gap: 10px;
  }

  .luxe-trust-payments-showcase__trust-item-{{ block.id }} {
    border-radius: 16px;
    padding: 14px 16px;
    background: {{ trust_card_background }};
    border: 1px solid {{ trust_card_border }};
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .luxe-trust-payments-showcase__trust-icon-{{ block.id }} {
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: {{ icon_background }};
    flex-shrink: 0;
  }

  .luxe-trust-payments-showcase__trust-text-{{ block.id }} {
    font-size: 14px;
    line-height: 1.5;
    color: {{ heading_color }};
    font-weight: 600;
  }

  .luxe-trust-payments-showcase__partners-panel-{{ block.id }} {
    border-radius: 20px;
    padding: 18px;
    background: {{ partner_panel_background }};
    border: 1px solid {{ partner_panel_border }};
    align-self: stretch;
  }

  .luxe-trust-payments-showcase__partners-label-{{ block.id }} {
    margin: 0 0 14px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #7c5c2b;
  }

  .luxe-trust-payments-showcase__partners-grid-{{ block.id }} {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .luxe-trust-payments-showcase__partner-item-{{ block.id }} {
    border-radius: 14px;
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ partner_item_background }};
    border: 1px solid {{ partner_item_border }};
    font-size: 13px;
    font-weight: 700;
    color: {{ heading_color }};
    text-align: center;
    padding: 8px;
  }

  @media screen and (min-width: 750px) {
    .luxe-trust-payments-showcase__grid-{{ block.id }} {
      grid-template-columns: 1.08fr 0.92fr;
    }
  }
{% endstyle %}

<div class="luxe-trust-payments-showcase-{{ block.id }}" {{ block.shopify_attributes }}>
  <div class="luxe-trust-payments-showcase__surface-{{ block.id }}">
    <div class="luxe-trust-payments-showcase__grid-{{ block.id }}">
      <div class="luxe-trust-payments-showcase__content-{{ block.id }}">
        {% if section_eyebrow != blank %}
          <div class="luxe-trust-payments-showcase__eyebrow-wrap-{{ block.id }}">
            <div class="luxe-trust-payments-showcase__eyebrow-{{ block.id }}">
              {{ section_eyebrow | escape }}
            </div>
          </div>
        {% endif %}

        {% if section_heading != blank %}
          <div class="luxe-trust-payments-showcase__heading-wrap-{{ block.id }}">
            <h2 class="luxe-trust-payments-showcase__heading-{{ block.id }}">
              {{ section_heading | escape }}
            </h2>
          </div>
        {% endif %}

        {% if section_subheading != blank %}
          <div class="luxe-trust-payments-showcase__subheading-wrap-{{ block.id }}">
            <p class="luxe-trust-payments-showcase__subheading-{{ block.id }}">
              {{ section_subheading | escape }}
            </p>
          </div>
        {% endif %}

        <div class="luxe-trust-payments-showcase__trust-list-{{ block.id }}">
          {% for index in (1..3) %}
            {% liquid
              assign trust_key = 'trust_point_' | append: index
              assign trust_value = showcase_content[trust_key]
            %}

            {% if trust_value != blank %}
              <div class="luxe-trust-payments-showcase__trust-item-{{ block.id }}">
                <div class="luxe-trust-payments-showcase__trust-icon-{{ block.id }}"></div>
                <div class="luxe-trust-payments-showcase__trust-text-{{ block.id }}">
                  {{ trust_value | escape }}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="luxe-trust-payments-showcase__partners-panel-{{ block.id }}">
        <p class="luxe-trust-payments-showcase__partners-label-{{ block.id }}">
          Payments and delivery
        </p>

        <div class="luxe-trust-payments-showcase__partners-grid-{{ block.id }}">
          {% for index in (1..4) %}
            {% liquid
              assign partner_key = 'partner_' | append: index
              assign partner_value = showcase_content[partner_key]
            %}

            {% if partner_value != blank %}
              <div class="luxe-trust-payments-showcase__partner-item-{{ block.id }}">
                {{ partner_value | escape }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trust & Payment Showcase",
  "target": "section",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ]
}
{% endschema %}