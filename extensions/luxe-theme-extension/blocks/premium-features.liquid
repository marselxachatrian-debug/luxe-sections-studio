        { "value": "shield", "label": "Shield" },
        { "value": "sparkles", "label": "Sparkles" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "crown", "label": "Crown" }
      ]
    },
    {
      "type": "text",
      "id": "feature_2_title",
