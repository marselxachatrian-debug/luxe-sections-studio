generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String   @id
  shop                String
  state               String
  isOnline            Boolean  @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean  @default(false)
  locale              String?
  collaborator        Boolean? @default(false)
  emailVerified       Boolean? @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShopSetupState {
  id                       String   @id @default(cuid())
  shop                     String   @unique
  appEmbedConfirmed        Boolean  @default(false)
  heroBlockConfirmed       Boolean  @default(false)
  trustBlockConfirmed      Boolean  @default(false)
  featuresBlockConfirmed   Boolean  @default(false)
  onboardingCompleted      Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}